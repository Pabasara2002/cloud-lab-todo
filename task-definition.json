{
  "family": "todo-task-cli",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "executionRoleArn": "arn:aws:iam::710514262881:role/ecs-task-execution-role-cli",
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "todo-container",
      "image": "710514262881.dkr.ecr.ap-south-1.amazonaws.com/cloud-lab-todo:latest",
      "portMappings": [
        { "containerPort": 3000, "hostPort": 3000, "protocol": "tcp" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/todo-task-cli",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
